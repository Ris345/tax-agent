# ── AWS ──────────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
S3_BUCKET_NAME=tax-agent-w2-123456789012-us-east-1   # W2TextractStack → BucketName
KMS_KEY_ID=arn:aws:kms:us-east-1:123456789012:key/…  # W2TextractStack → KmsKeyArn
PRESIGNED_URL_EXPIRY_SECONDS=3600

# ── Cognito (from CognitoStack CDK outputs) ───────────────────────────────────
COGNITO_REGION=us-east-1
COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX             # CognitoStack → UserPoolId
COGNITO_CLIENT_ID=XXXXXXXXXXXXXXXXXXXXXXXXXX          # CognitoStack → ClientId

# Retrieve client secret with:
#   aws cognito-idp describe-user-pool-client \
#     --user-pool-id us-east-1_XXXXXXXXX \
#     --client-id XXXXXXXXXXXXXXXXXXXXXXXXXX \
#     --query UserPoolClient.ClientSecret --output text
COGNITO_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# CognitoStack → HostedUiDomain
COGNITO_DOMAIN=https://tax-agent-123456789012.auth.us-east-1.amazoncognito.com

# Must match a CallbackUrl registered in the Cognito App Client.
COGNITO_REDIRECT_URI=http://localhost:3000/api/auth/callback

# Production (set in your hosting env, not .env.local):
# COGNITO_REDIRECT_URI=https://app.example.com/api/auth/callback
# COGNITO_LOGOUT_URI=https://app.example.com/login

# ── Document API & PDF Generator Lambda function names (TaxPipelineStack) ─────
DOCUMENT_API_FUNCTION_NAME=TaxPipelineStack-DocumentApiFunction
PDF_GENERATOR_FUNCTION_NAME=TaxPipelineStack-PDFGeneratorFunction
